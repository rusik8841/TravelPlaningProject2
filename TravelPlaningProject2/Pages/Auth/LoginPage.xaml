<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelPlaningProject2.Pages.Auth.LoginPage"
             Title="Вход"
             BackgroundColor="#F5F5F7">

    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Spacing="20" 
                               VerticalOptions="Center" 
                               HorizontalOptions="Center" 
                               Padding="30">

                <!-- Логотип -->
                <Image Source="dotnet_bot.png" 
                       HeightRequest="100" 
                       Aspect="AspectFit"/>

                <!-- Заголовок -->
                <Label Text="Travel Planner" 
                   FontSize="32" 
                   FontAttributes="Bold" 
                   TextColor="#2196F3" 
                   HorizontalOptions="Center" />

                <Label Text="Войдите в свой аккаунт" 
                   FontSize="16" 
                   TextColor="#666" 
                   HorizontalOptions="Center" />

                <!-- Поле Логин/Email -->
                <Entry Placeholder="Email или Логин" 
                   Text="{Binding Login}"
                   TextColor="Black" 
                   PlaceholderColor="Gray"
                   Keyboard="Email"
                   BackgroundColor="White"
                   Margin="0, 20, 0, 0" />

                <!-- Поле Пароль -->
                <Entry Placeholder="Пароль" 
                   Text="{Binding Password}"
                   TextColor="Black" 
                   PlaceholderColor="Gray"
                   IsPassword="True" 
                   BackgroundColor="White" />

                <!-- Кнопка входа -->
                <Button Text="Войти" 
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotBusy}" 
                    BackgroundColor="#2196F3" 
                    TextColor="White" 
                    CornerRadius="10" 
                    HeightRequest="50" 
                    FontAttributes="Bold" />

                <!-- Индикатор загрузки -->
                <ActivityIndicator IsRunning="{Binding IsBusy}" 
                               IsVisible="{Binding IsBusy}" 
                               Color="#2196F3" 
                               HeightRequest="30" />

                <!-- Ошибка -->
                <Label Text="{Binding ErrorMessage}" 
                   TextColor="Red" 
                   HorizontalOptions="Center" 
                   IsVisible="{Binding IsErrorVisible}" />
                <!-- Ссылка на регистрацию -->
                <HorizontalStackLayout Spacing="5" 
                                     HorizontalOptions="Center" 
                                     Margin="0,30">
                    <Label Text="Нет аккаунта?" 
                           TextColor="Gray" 
                           VerticalOptions="Center"/>
                    <Button Text="Зарегистрироваться"
                            Clicked="ToRegisterPage"
                            BackgroundColor="Transparent"  
                            TextColor="#2196F3" 
                            Padding="0"  
                            VerticalOptions="Center" 
                            FontAttributes="Bold"/>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>