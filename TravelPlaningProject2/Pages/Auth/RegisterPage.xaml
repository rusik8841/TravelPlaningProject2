<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelPlaningProject2.Pages.Auth.RegisterPage"
             Title="Регистрация"
             BackgroundColor="#F9FAFB">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <!-- Заголовок -->
            <Label Text="Создание аккаунта" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#2196F3" 
                   HorizontalOptions="Center" />

            <!-- Имя -->
            <Entry Placeholder="Ваше Имя" 
                   Text="{Binding Name}"
                   TextColor="Black" 
                   PlaceholderColor="Gray"
                   BackgroundColor="White" />

            <!-- Фамилия -->
            <Entry Placeholder="Ваша Фамилия" 
                   Text="{Binding Surname}"
                   TextColor="Black" 
                   PlaceholderColor="Gray"
                   BackgroundColor="White" />

            <!-- Email -->
            <Entry Placeholder="Email адрес" 
                   Text="{Binding Email}"
                   TextColor="Black" 
                   PlaceholderColor="Gray"
                   Keyboard="Email"
                   BackgroundColor="White" />

            <!-- Пароль -->
            <Entry Placeholder="Придумайте пароль" 
                   Text="{Binding Password}"
                   TextColor="Black" 
                   PlaceholderColor="Gray"
                   IsPassword="True" 
                   BackgroundColor="White" />

            <!-- Кнопка регистрации -->
            <Button Text="Зарегистрироваться" 
                    Command="{Binding RegisterCommand}"
                    IsEnabled="{Binding IsNotBusy}" 
                    BackgroundColor="#2196F3" 
                    TextColor="White" 
                    CornerRadius="10" 
                    HeightRequest="50" 
                    FontAttributes="Bold" 
                    Margin="0, 20, 0, 0" />

            <!-- Индикатор загрузки -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                               IsVisible="{Binding IsBusy}" 
                               Color="#2196F3" />

            <!-- Ошибка -->
            <Label Text="{Binding ErrorMessage}" 
                   TextColor="Red" 
                   HorizontalOptions="Center" 
                   IsVisible="{Binding IsErrorVisible}" />

            <!-- Ссылка на вход -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Label Text="Уже есть аккаунт?" TextColor="Black" />
                <Label Text="Войти" 
                       TextColor="#2196F3" 
                       FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>