<Shell
    x:Class="TravelPlaningProject2.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TravelPlaningProject2"
    xmlns:auth="clr-namespace:TravelPlaningProject2.Pages.Auth"
    xmlns:trips="clr-namespace:TravelPlaningProject2.Pages.Trips"
    xmlns:profile="clr-namespace:TravelPlaningProject2.Pages.Profile"
    Shell.FlyoutBehavior="Flyout"
    Title="Travel Planner">

    <!-- Страницы авторизации (скрыты из меню) -->
    <ShellContent Title="Login" ContentTemplate="{DataTemplate auth:LoginPage}" Route="LoginPage" FlyoutItemIsVisible="False" />
    <ShellContent Title="Register" ContentTemplate="{DataTemplate auth:RegisterPage}" Route="RegisterPage" FlyoutItemIsVisible="False" />

    <!-- Главная: Поездки -->
    <FlyoutItem Title="Поездки" Icon="icon.png">
        <ShellContent Title="Мои поездки" ContentTemplate="{DataTemplate trips:TripsPage}" Route="TripsPage" />
    </FlyoutItem>

    <!-- Детали поездки (скрыта) -->
    <ShellContent Title="Детали" ContentTemplate="{DataTemplate trips:TripDetailsPage}" Route="TripDetailsPage" FlyoutItemIsVisible="False" />

    <!-- Профиль -->
    <FlyoutItem Title="Профиль" Icon="icon.png">
        <ShellContent Title="Мой профиль" ContentTemplate="{DataTemplate profile:ProfilePage}" Route="ProfilePage" />
    </FlyoutItem>
</Shell>