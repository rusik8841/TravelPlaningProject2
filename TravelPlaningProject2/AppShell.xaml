<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TravelPlaningProject2.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TravelPlaningProject2"
    xmlns:auth="clr-namespace:TravelPlaningProject2.Pages.Auth"
    xmlns:trips="clr-namespace:TravelPlaningProject2.Pages.Trips"
    xmlns:profile="clr-namespace:TravelPlaningProject2.Pages.Profile"
    Shell.FlyoutBehavior="Flyout"
    Title="Travel Planner">

    <!-- Страница входа (скрыта из меню) -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate auth:LoginPage}"
        Route="LoginPage"
        FlyoutItemIsVisible="False" />

    <!-- Страница регистрации (скрыта из меню) -->
    <ShellContent
        Title="Register"
        ContentTemplate="{DataTemplate auth:RegisterPage}"
        Route="RegisterPage"
        FlyoutItemIsVisible="False" />

    <!-- Главная страница - Поездки -->
    <FlyoutItem Title="Поездки" Icon="icon.png">
        <ShellContent
            Title="Мои поездки"
            ContentTemplate="{DataTemplate trips:TripsPage}"
            Route="TripsPage" />
    </FlyoutItem>

    <!-- Страница деталей поездки (скрыта из меню) -->
    <ShellContent
        Title="Детали поездки"
        ContentTemplate="{DataTemplate trips:TripDetailsPage}"
        Route="TripDetailsPage"
        FlyoutItemIsVisible="False" />

    <!-- Страница профиля -->
    <FlyoutItem Title="Профиль" Icon="icon.png">
        <ShellContent
            Title="Мой профиль"
            ContentTemplate="{DataTemplate profile:ProfilePage}"
            Route="ProfilePage" />
    </FlyoutItem>

</Shell>